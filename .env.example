# Server-side only — never commit real secrets. Copy to `.env` locally.
# Add the same keys in your host dashboard (e.g. Vercel → Environment Variables).

# Inbox that receives form submissions (production: client business address).
BUSINESS_EMAIL=hello@premierdoulas.com

# SMTP — use either Example A or Example B below depending on GoDaddy product.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# -----------------------------------------------------------------------------
# Example A — GoDaddy Professional Email (typical)
# SMTP_HOST=smtpout.secureserver.net
# SMTP_PORT=465
# SMTP_USER=hello@premierdoulas.com
# SMTP_PASS=the_email_or_app_password
# BUSINESS_EMAIL=hello@premierdoulas.com
#
# Example B — GoDaddy Microsoft 365 (typical)
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USER=hello@premierdoulas.com
# SMTP_PASS=the_email_or_app_password
# BUSINESS_EMAIL=hello@premierdoulas.com
# -----------------------------------------------------------------------------

# Optional: override From if your provider requires a verified sender string.
# SMTP_FROM=hello@premierdoulas.com

# Optional: browser API base if the API is not same-origin.
# VITE_CONTACT_API_URL=

# Optional: local mail API port (default 3001).
# CONTACT_API_PORT=3001

# LOCAL QUICK TEST: run `npm run dev` with no SMTP set — the terminal prints an
# Ethereal preview URL for each send. For real delivery, set SMTP_* and BUSINESS_EMAIL.
